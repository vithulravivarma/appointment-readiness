{
  "name": "appointment-readiness-monorepo",
  "private": true,
  "workspaces": [
    "services/*",
    "shared/*"
  ],
  "scripts": {
    "dev:readiness": "npm run dev --workspace=services/readiness-engine",
    "migrate": "ts-node scripts/migrate.ts",
    "backfill:agent-desk": "ts-node scripts/backfill-agent-desk-history.ts",
    "whatsapp:replay-failed": "ts-node scripts/replay-whatsapp-failed-inbound.ts",
    "whatsapp:prune-events": "ts-node scripts/prune-webhook-events.ts",
    "test": "jest",
    "smoke": "./scripts/e2e-smoke.sh",
    "test:isolation": "bash ./scripts/e2e-chat-isolation.sh",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "setup": "./scripts/setup-local.sh"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  }
}
